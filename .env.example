# OpenAI-Compatible API 配置
# 复制此文件为 .env 并填入真实配置

# === App ===
# DEBUG=false
# PORT=8080

# === Database ===
# DATABASE_URL=sqlite:///./inkling.db

# === LLM Provider ===
# 选项: mock / moonshot / openai-compatible
# PROVIDER_TYPE=mock

# Moonshot / DeepSeek / OpenAI 配置（provider_type 非 mock 时必填）
# LLM_API_KEY=<your-api-key>
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
